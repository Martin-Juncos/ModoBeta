{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/nosotros",
      "destination": "/index.html"
    },
    {
      "source": "/soluciones",
      "destination": "/index.html"
    },
    {
      "source": "/proyectos",
      "destination": "/index.html"
    },
    {
      "source": "/contacto",
      "destination": "/index.html"
    }
  ]
}
